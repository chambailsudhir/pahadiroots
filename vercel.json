{
  "rewrites": [
    { "source": "/terms", "destination": "/terms.html" },
    { "source": "/terms/:path*", "destination": "/terms.html" },
    { "source": "/privacy", "destination": "/terms.html" },
    { "source": "/returns", "destination": "/terms.html" },
    { "source": "/shipping", "destination": "/terms.html" },
    { "source": "/product", "destination": "/product.html" },
    { "source": "/products/:slug*", "destination": "/product.html" },
    { "source": "/account", "destination": "/account.html" },
    { "source": "/order-confirmation", "destination": "/order-confirmation.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
      ]
    }
  ]
}
