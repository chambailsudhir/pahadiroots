{
  "rewrites": [
    { "source": "/reset-password", "destination": "/reset-password.html" },
    { "source": "/terms", "destination": "/terms.html" },
    { "source": "/terms/:path*", "destination": "/terms.html" },
    { "source": "/privacy", "destination": "/terms.html" },
    { "source": "/returns", "destination": "/terms.html" },
    { "source": "/shipping", "destination": "/terms.html" },
    { "source": "/product", "destination": "/product.html" },
    { "source": "/products/:slug*", "destination": "/product.html" },
    { "source": "/account", "destination": "/account.html" },
    { "source": "/order-confirmation", "destination": "/order-confirmation.html" },
    { "source": "/our-story", "destination": "/about.html" },
    { "source": "/admin", "destination": "/admin.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
      ]
    },
    {
      "source": "/:path*.html",
      "headers": [
        { "key": "Cache-Control", "value": "s-maxage=300, stale-while-revalidate=600" }
      ]
    },
    {
      "source": "/js/:path*",
      "headers": [
        { "key": "Cache-Control", "value": "s-maxage=3600, stale-while-revalidate=86400" }
      ]
    },
    {
      "source": "/css/:path*",
      "headers": [
        { "key": "Cache-Control", "value": "s-maxage=3600, stale-while-revalidate=86400" }
      ]
    },
    {
      "source": "/admin",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow, noarchive" },
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate, private" },
        { "key": "Pragma", "value": "no-cache" }
      ]
    },
    {
      "source": "/admin.html",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow, noarchive" },
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate, private" },
        { "key": "Pragma", "value": "no-cache" }
      ]
    }
  ]
}
